# google-reviews-download — environment template
#
# Copy to `.env.local` for local dev. `.env.local` is gitignored.
# When SF_API_KEY is unset, lib/semanticforce/client.ts returns fixture
# data from mocks/semanticforce/ — that is the default dev mode.

# --- SemanticForce (reviews data source) ---
# Real key arrives in Phase 4 (human-gated). Leave blank for fixture mode.
SF_API_KEY=
# Base URL for the SemanticForce API. See docs/semanticforce-api.md.
SF_API_BASE=https://api.semanticforce.net

# --- Vercel KV (review cache, 24h TTL keyed by normalised place_id) ---
# Provided automatically when you link a Vercel KV store via `vercel env pull`.
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# --- Analytics (optional, env-gated) ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
