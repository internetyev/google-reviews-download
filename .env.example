# google-reviews-download — environment template
#
# Copy to `.env.local` for local dev (`.env.local` is gitignored).
# With REVIEWS_PROVIDER unset (or `mock`) the app serves offline fixtures from
# mocks/ — the zero-quota default dev mode.

# --- Reviews provider switch (lib/reviews/provider.ts) ---
# serpapi | semanticforce | mock   (default: mock → offline fixtures)
# `serpapi` is the current TRIAL data source; `semanticforce` is the intended
# production source (same internal contract — swapping is just this value).
REVIEWS_PROVIDER=mock

# --- SerpApi (REVIEWS_PROVIDER=serpapi) ---
# Free tier: 250 searches/mo per key. Set 1–3 keys; the client rotates them to
# stretch the ~750/mo trial quota. See docs/serpapi-reviews.md. Either set the
# single SERPAPI_API_KEY or the numbered set (or both — deduped).
SERPAPI_API_KEY=
SERPAPI_API_KEY_1=
SERPAPI_API_KEY_2=
SERPAPI_API_KEY_3=

# --- SemanticForce (REVIEWS_PROVIDER=semanticforce — intended production) ---
# Real key is human-gated (Phase 4 / L4.1). Leave blank otherwise.
SF_API_KEY=
# Base URL for the SemanticForce API. See docs/semanticforce-api.md.
SF_API_BASE=https://api.semanticforce.net

# --- Vercel KV (review cache, 24h TTL keyed by normalised data_id/place_id) ---
# Provided automatically when you link a Vercel KV store via `vercel env pull`.
# When unset, the cache falls back to a process-local Map (fine for dev; a
# single-instance prod still caches, but not across instances — link KV for prod).
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# --- Public site URL (used by app/robots.ts + app/sitemap.ts) ---
# Set to the deployed origin (no trailing slash), e.g. https://googlereviewsdownload.com.
# Until L5.1 picks a domain, robots/sitemap fall back to https://googlereviewsdownload.com.
NEXT_PUBLIC_SITE_URL=

# --- Analytics (optional, env-gated) ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
